GNP <- matrix(0, dim(hamilton84GNP)[1]*dim(hamilton84GNP)[2], 1 )
xk <- 1
for (xi in 1:dim(hamilton84GNP)[1] ){
for (xj in 1:dim(hamilton84GNP)[2]){
GNP[xk] <- hamilton84GNP[xi,xj]
xk <- xk +1
}
}
